{
  "name": "@stockpackz/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the StockPackz protocol — typed reads, writes, and event streams for packs, openings, XP, and the jackpot.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "viem": "^2.21.0"
  },
  "keywords": ["stockpackz", "robinhood-chain", "tokenized-stocks", "uniswap-v4"],
  "repository": {
    "type": "git",
    "url": "https://github.com/stockpackz/stockpackz.git",
    "directory": "sdk"
  }
}
